# Sample .env for the mapbiker-tile-bake pipeline.
#
# Copy this file to `.env` (gitignored) and fill in your real R2
# credentials. The CLI runners (`bake.run_dgm10`, `bake.run_srtm`,
# `bake.run_valhalla`, etc.) load `.env` automatically via
# python-dotenv at import time.
#
# # Where to get the values
#
# Cloudflare Dashboard → R2 (left sidebar):
#   - Account ID                  → R2_ENDPOINT, R2_PUBLIC_URL
#   - "Manage R2 API Tokens"      → R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY
#     Create a new token with "Object Read & Write" on the
#     `mapbiker-tiles` bucket. Copy both halves into the variables
#     below — the secret is shown ONCE.
#   - Bucket settings → Public R2.dev URL → R2_PUBLIC_URL
#     (You also need to enable "Public R2.dev access" on the bucket
#     for iOS to be able to fetch baked assets anonymously.)
#
# # Security
#
# Never commit a real `.env` to git. The `.gitignore` excludes it
# but a `git add -A` could still pull it in — verify before each
# commit. The Access Key + Secret grant read+write to your bucket;
# anyone with them can upload, overwrite, or delete tiles.

# R2 access key ID — 32 hex chars
R2_ACCESS_KEY_ID=replace-me-with-32-hex-chars

# R2 secret access key — 64 hex chars. Visible only once at creation.
R2_SECRET_ACCESS_KEY=replace-me-with-64-hex-chars

# S3-compatible endpoint for your R2 account. Format:
# https://<account-id>.r2.cloudflarestorage.com
# Account ID is the 32-char hex string shown in Cloudflare → R2 home.
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Target bucket. Created once via `wrangler r2 bucket create
# mapbiker-tiles` (or via the dashboard). The bake-pipeline assumes
# this exact name in the upload helpers.
R2_BUCKET=mapbiker-tiles

# Public read URL — auto-generated when you enable "Public R2.dev"
# on the bucket. Format:
# https://pub-<random32hex>.r2.dev
# This is what iOS hits to fetch tiles. NO authentication on this
# subdomain — assume the contents are public.
R2_PUBLIC_URL=https://pub-your-random-hex.r2.dev
